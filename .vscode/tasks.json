{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build and Run Current Test",
      "type": "shell",
      "command": "cmake --build build && ./build/${fileBasenameNoExtension}",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    }    
  ]
}


